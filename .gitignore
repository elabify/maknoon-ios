# Keeps local builds clean; build artifacts are not tracked.

# macOS
.DS_Store

# Xcode
build/
DerivedData/
*.xcarchive
*.ipa
*.xcodeproj/xcuserdata/
.swiftpm/

# Swift Package Manager
.build/

# Rust
target/

# Node / TypeScript (elabify-core)
node_modules/
dist/

# Ledger build outputs (regenerated by `make ios`)
ledger-*/ios/*.xcframework/
ledger-*/ios/bindings/
