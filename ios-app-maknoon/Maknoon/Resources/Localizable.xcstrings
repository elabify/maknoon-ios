    "Sweeps your Identity Sandwich seed for accounts that already have on-chain activity. Useful when restoring from a backup or migrating from another wallet built on the same 24-word recovery phrase.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يمسح بذرة Identity Sandwich الخاصة بك بحثًا عن الحسابات التي لها نشاط على السلسلة بالفعل. مفيد عند الاستعادة من نسخة احتياطية أو الترحيل من محفظة أخرى مبنية على عبارة الاسترداد نفسها المكوّنة من 24 كلمة."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "扫描您的 Identity Sandwich 种子，查找已有链上活动的账户。在从备份恢复，或从基于同一 24 词恢复短语构建的另一个钱包迁移时很有用。"
          }
        }
      }
    },
    "Switches to Light between 6:00 AM and 6:00 PM local time, otherwise Dark.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يتحول إلى الفاتح بين 6:00 صباحاً و 6:00 مساءً بالتوقيت المحلي، وإلى الداكن في غير ذلك."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Switches to Light between 6:00 AM and 6:00 PM local time, otherwise Dark."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "本地时间 6:00 至 18:00 切换为浅色，其他时间使用深色。"
          }
        }
      }
    },
    "Symbol": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "الرمز"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "符号"
          }
        }
      }
    },
    "Symbol \"%@\", name \"%@\", %@ decimals read from the contract. You can edit before adding if any look wrong.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Symbol \"%1$@\", name \"%2$@\", %3$@ decimals read from the contract. You can edit before adding if any look wrong."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "تمت قراءة الرمز \"%@\" والاسم \"%@\" و%@ منزلة عشرية من العقد. يمكنك التعديل قبل الإضافة إذا بدا أي منها خاطئًا."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "从合约读取的代号 \"%@\"、名称 \"%@\"、精度 %@ 位。如果有任何看起来不对，您可以在添加前编辑。"
          }
        }
      }
    },
