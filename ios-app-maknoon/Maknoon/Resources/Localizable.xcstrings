    "Worst-case total exceeds balance. Lower the amount or wait for cheaper gas.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "الإجمالي في أسوأ الحالات يتجاوز الرصيد. خفّض المبلغ أو انتظر غازاً أرخص."
          }
        },
