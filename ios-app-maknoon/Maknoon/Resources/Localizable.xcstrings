      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "اتصل واقرأ الرقم التسلسلي"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
