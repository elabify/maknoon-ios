    "Submits your name and date of birth to the selected issuer for an OpenSanctions check. Your photo and chip data stay on this device.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يرسل اسمك وتاريخ ميلادك إلى جهة الإصدار المحددة لإجراء فحص OpenSanctions. تبقى صورتك وبيانات الشريحة على هذا الجهاز."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "将您的姓名和出生日期提交给所选发行方进行 OpenSanctions 检查。您的照片和芯片数据保留在此设备上。"
          }
        }
      }
    },
    "Submitted; anchoring in background": {
      "extractionState": "manual",
      "localizations": {
