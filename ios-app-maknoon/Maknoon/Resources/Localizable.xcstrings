          "stringUnit": {
            "state": "needs_review",
            "value": "الرقم الشخصي"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "个人编号"
          }
        }
      }
    },
    "Pick a device": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "اختر جهازاً"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pick a device"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "选择一个设备"
          }
        }
      }
    },
    "Pick a network to create your first wallet on it. You can add more wallets and additional networks later.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "اختر شبكة لإنشاء أول محفظة لك عليها. يمكنك إضافة المزيد من المحافظ وشبكات إضافية لاحقاً."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pick a network to create your first wallet on it. You can add more wallets and additional networks later."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "选择一个网络以在其上创建第一个钱包。之后您还可以添加更多钱包和网络。"
          }
        }
      }
    },
    "Pick an issuer or enter a custom URL.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "اختر جهة إصدار أو أدخل عنوان URL مخصصًا."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "选择一个发行方或输入自定义网址。"
          }
        }
      }
    },
    "Pick from contacts": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "اختر من جهات الاتصال"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pick from contacts"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "从联系人中选择"
          }
        }
      }
    },
    "Pick the chain this contact lives on. Different chains have different address formats.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "اختر السلسلة التي تعيش عليها جهة الاتصال هذه. تختلف صيغ العناوين بين السلاسل."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pick the chain this contact lives on. Different chains have different address formats."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "选择此联系人所属的链。不同的链使用不同的地址格式。"
          }
        }
      }
    },
    "Pick the encrypted backup file you saved earlier (anywhere in iCloud Drive, On My iPhone, or another Files-app location). You will need the passphrase.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "اختر ملف النسخة الاحتياطية المشفر الذي حفظته سابقاً (في أي مكان في iCloud Drive أو On My iPhone أو أي موقع آخر في تطبيق الملفات). ستحتاج إلى عبارة المرور."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pick the encrypted backup file you saved earlier (anywhere in iCloud Drive, On My iPhone, or another Files-app location). You will need the passphrase."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "选择之前保存的加密备份文件（位于 iCloud Drive、“在我的 iPhone 上”或其他“文件”应用位置均可）。需要使用口令短语。"
          }
        }
      }
    },
    "Pickup URLs from these hosts are accepted silently. Other hosts trigger a one-time-trust prompt at Receive time. Paste a full URL or just a hostname; only the host is stored.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "تُقبَل عناوين URL للاستلام من هذه المضيفين بصمت. تستدعي المضيفات الأخرى مطالبة ثقة لمرة واحدة عند الاستلام. الصق عنوان URL كاملاً أو اسم مضيف فقط، يُخزَّن المضيف فقط."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pickup URLs from these hosts are accepted silently. Other hosts trigger a one-time-trust prompt at Receive time. Paste a full URL or just a hostname; only the host is stored."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "来自这些主机的领取 URL 将静默接受。其他主机会在接收时触发一次性信任提示。可粘贴完整 URL 或仅主机名，只有主机名会被保存。"
          }
        }
      }
    },
    "Pickup URLs from these hosts are accepted silently. Other hosts trigger a one-time-trust prompt at Receive time. Paste a full URL or just a hostname; only the host is stored. The shield turns green only when the issuer is reachable over a valid TLS connection and returns a valid issuer document; pull down to re-check.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "تُقبل عناوين URL للاستلام من هذه المضيفات بصمت. أما المضيفات الأخرى فتؤدي إلى ظهور مطالبة بثقة لمرة واحدة عند الاستلام. الصق عنوان URL كاملًا أو اسم المضيف فقط؛ لا يُخزَّن سوى المضيف. يتحول الدرع إلى اللون الأخضر فقط عندما تكون جهة الإصدار قابلة للوصول عبر اتصال TLS صالح وتُرجع مستند جهة إصدار صالحًا؛ اسحب للأسفل لإعادة التحقق."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "来自这些主机的取件 URL 会被静默接受。其他主机会在接收时触发一次性信任提示。粘贴完整 URL 或仅主机名；仅存储主机。仅当发行方可通过有效的 TLS 连接访问并返回有效的发行方文档时，盾牌才会变绿；下拉以重新检查。"
          }
        }
      }
    },
    "Pickup URLs from trusted issuers fetch silently. Unknown hosts will ask for one-time trust before any network call. Manage the trusted list under Settings → Identity.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "تُجلَب عناوين URL للاستلام من المصدرين الموثوقين بصمت. تطلب المضيفات غير المعروفة ثقة لمرة واحدة قبل أي مكالمة شبكة. أدر القائمة الموثوقة من الإعدادات ← الهوية."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pickup URLs from trusted issuers fetch silently. Unknown hosts will ask for one-time trust before any network call. Manage the trusted list under Settings → Identity."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "来自可信发行方的领取 URL 将静默获取。未知主机会在任何网络调用前请求一次性信任。可在“设置 → 身份”中管理信任列表。"
          }
        }
      }
    },
    "Pinned cert SHA-256 (optional)": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "SHA-256 لشهادة مثبتة (اختياري)"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pinned cert SHA-256 (optional)"
