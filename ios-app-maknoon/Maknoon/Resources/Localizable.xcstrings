    "0 is the de facto primary identity. Higher indices give you additional identities from the same seed; each derives a different npub." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "الفهرس 0 هو الهوية الأساسية بحكم الأمر الواقع. الفهارس الأعلى تمنحك هويات إضافية من نفس البذرة، وكل منها يشتق npub مختلفاً."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "0 is the de facto primary identity. Higher indices give you additional identities from the same seed; each derives a different npub."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "0 是事实上的主身份。更高的索引可从同一种子派生出额外的身份，每个身份对应不同的 npub。"
          }
        }
      }
    },
