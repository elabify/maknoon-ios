    "Register a YubiKey or a Ledger (Security Key app), then add it from the device's detail screen below to require a second factor on every Identity Sandwich unlock.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "سجّل YubiKey أو Ledger (تطبيق Security Key)، ثم أضفه من شاشة تفاصيل الجهاز أدناه لطلب عامل ثانٍ عند كل فك قفل لـ Sandwich الهوية."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Register a YubiKey or a Ledger (Security Key app), then add it from the device's detail screen below to require a second factor on every Identity Sandwich unlock."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "注册 YubiKey 或 Ledger（Security Key 应用），然后在下方设备详情页将其添加，使每次身份三明治解锁都需要第二因素。"
          }
        }
      }
    },
    "Register a YubiKey or a Ledger Nano X from Settings > Devices, then return here to enable it as a second factor.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "سجّل YubiKey أو Ledger Nano X من الإعدادات > الأجهزة، ثم عُد هنا لتفعيله كعامل ثانٍ."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Register a YubiKey or a Ledger Nano X from Settings > Devices, then return here to enable it as a second factor."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "请在“设置 > 设备”中注册 YubiKey 或 Ledger Nano X，然后返回此处将其启用为第二因素。"
          }
        }
      }
    },
