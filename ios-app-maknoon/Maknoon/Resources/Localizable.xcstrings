    "Connect a supported transport so Maknoon can read the device's serial. Adding it to a network wallet is a separate step from the device's detail screen.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "وصّل وسيلة نقل مدعومة حتى يتمكن Maknoon من قراءة الرقم التسلسلي للجهاز. إضافته إلى محفظة شبكة خطوة منفصلة من شاشة تفاصيل الجهاز."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "连接受支持的传输方式，以便 Maknoon 读取设备的序列号。将其添加到网络钱包是设备详情界面中的另一步操作。"
          }
        }
      }
    },
    "Connect and add wallet": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "اتصل وأضف محفظة"
