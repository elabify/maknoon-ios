    "Disable TLS validation only if your hub uses a self-signed certificate you trust.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "عطّل التحقق من TLS فقط إذا كانت المحطة الخاصة بك تستخدم شهادة موقّعة ذاتيًا تثق بها."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "仅当您的 hub 使用您信任的自签名证书时才停用 TLS 验证。"
          }
        }
      }
    },
    "Disable TLS validation only if your hub uses a self-signed certificate you trust. Tor toggle is saved but not yet wired; enabling does nothing until the Tor transport ships.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "عطّل التحقق من TLS فقط إذا كان مركزك يستخدم شهادة موقعة ذاتياً تثق بها. يُحفظ مفتاح Tor لكنه غير مفعّل بعد، التفعيل لا يفعل شيئاً حتى يتم إطلاق ناقل Tor."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Disable TLS validation only if your hub uses a self-signed certificate you trust. Tor toggle is saved but not yet wired; enabling does nothing until the Tor transport ships."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "仅在您的 hub 使用您信任的自签名证书时才关闭 TLS 校验。Tor 开关已保存但尚未接入，启用它在 Tor 传输上线前不会产生效果。"
          }
        }
      }
    },
