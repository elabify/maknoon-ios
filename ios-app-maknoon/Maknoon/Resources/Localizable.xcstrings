    "Bitcoin's chain is load-bearing: Mainnet, Testnet3, and Signet derive different addresses, so pick it before you add or discover.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "شبكة Bitcoin أساسية: Mainnet وTestnet3 وSignet تشتق عناوين مختلفة، لذا اخترها قبل الإضافة أو الاكتشاف."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Bitcoin 的网络至关重要：Mainnet、Testnet3 和 Signet 会派生不同的地址，因此请在添加或发现前先选择它。"
          }
        }
      }
    },
