    "Adding a network wallet from this device happens inside the network's settings page so you can choose which account index to use, run a discovery scan, and pre-fund the address before signing.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "تتم إضافة محفظة الشبكة من هذا الجهاز داخل صفحة إعدادات الشبكة حتى تتمكن من اختيار فهرس الحساب المطلوب، وتشغيل فحص اكتشاف، وتمويل العنوان قبل التوقيع."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Adding a network wallet from this device happens inside the network's settings page so you can choose which account index to use, run a discovery scan, and pre-fund the address before signing."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "从此设备添加网络钱包是在对应网络的设置页面中完成的，您可以选择使用哪个账户索引、运行发现扫描，并在签名前向地址预先注入资金。"
          }
        }
      }
    },
