    "Only do this if every enrolled device is gone. You'll need your 24-word paper seed to restore.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "افعل ذلك فقط إذا اختفى كل جهاز مسجل. ستحتاج إلى بذرة الورق المكونة من 24 كلمة للاستعادة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only do this if every enrolled device is gone. You'll need your 24-word paper seed to restore."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "仅在所有已注册设备都已丢失时才执行此操作。您需要使用 24 个纸质助记词才能恢复。"
          }
        }
      }
    },
    "Only do this if every enrolled security key is gone. You'll need your encrypted backup or 24-word paper seed to restore.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "لا تفعل هذا إلا إذا فُقدت كل مفاتيح الأمان المسجَّلة. ستحتاج إلى نسختك الاحتياطية المشفّرة أو عبارة الاسترداد الورقية المكونة من 24 كلمة للاستعادة."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "仅当所有已注册的安全密钥都丢失时才执行此操作。您需要加密备份或 24 个单词的纸质恢复短语才能恢复。"
          }
        }
      }
    },
