    "%@ credential%@ will move back to All. The credentials themselves are not deleted.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ credential%2$@ will move back to All. The credentials themselves are not deleted."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%@ من بيانات الاعتماد%@ ستعود إلى الكل. لا يتم حذف بيانات الاعتماد نفسها."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%@ 个凭证%@将移回全部。凭证本身不会被删除。"
          }
        }
      }
    },
