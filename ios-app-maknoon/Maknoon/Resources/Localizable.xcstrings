    "Broadcast sends your identity to the merchant first; the payment is only sent on-chain once the merchant has received it.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يرسل البث هويتك إلى التاجر أولًا؛ ولا تُرسل الدفعة على السلسلة إلا بعد استلام التاجر لها."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "广播会先将您的身份发送给商户；只有在商户收到后，才会将付款发送上链。"
