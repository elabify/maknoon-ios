    "Bumps transaction priority during congestion. 0 is fine for normal sends. Typical congestion values: 10000 to 100000.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يرفع أولوية المعاملة أثناء الازدحام. القيمة 0 مناسبة للإرسال العادي. القيم المعتادة عند الازدحام: 10000 إلى 100000."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "在网络拥堵时提升交易优先级。普通发送时设为 0 即可。拥堵时的典型值：10000 至 100000。"
          }
        }
      }
    },
