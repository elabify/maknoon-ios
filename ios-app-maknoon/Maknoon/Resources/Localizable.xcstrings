          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "同一钱包可在每个 Solana 集群上使用，\"打开于\"会选择先打开哪一个。账户编号会自动填入下一个可用编号。您将通过生物识别或密码确认一次。"
          }
        }
      }
    },
