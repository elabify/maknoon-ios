    "Solana addresses are base58 32-byte Ed25519 public keys. Cluster-agnostic: the same address works on Mainnet, Devnet, and Testnet.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "عناوين Solana هي مفاتيح عامة Ed25519 بحجم 32 بايت بترميز base58. مستقلة عن المجموعة: العنوان نفسه يعمل على Mainnet وDevnet وTestnet."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Solana 地址是 base58 编码的 32 字节 Ed25519 公钥。与集群无关：同一地址可在 Mainnet、Devnet 和 Testnet 上使用。"
          }
        }
      }
    },
