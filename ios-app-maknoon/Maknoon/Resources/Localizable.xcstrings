    "Hardware-wallet Ethereum signing is not yet shipped. Use a software wallet for now.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "توقيع Ethereum عبر محفظة الأجهزة غير متوفر بعد. استخدم محفظة برمجية في الوقت الحالي."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "硬件钱包的 Ethereum 签名功能尚未推出。请暂时使用软件钱包。"
          }
        }
      }
    },
    "Have the verifier scan this QR with their Elabify app. The presentation is fetched once and then gone.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "اطلب من المحقق فحص رمز QR هذا بتطبيق Elabify الخاص به. يتم جلب العرض مرة واحدة ثم يختفي."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Have the verifier scan this QR with their Elabify app. The presentation is fetched once and then gone."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "让验证方使用其 Elabify 应用扫描此二维码。展示信息仅可被获取一次，之后即失效。"
          }
        }
      }
    },
