          }
        }
      }
    },
    "Enter the 6-digit pairing code shown on your Trezor.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "أدخل رمز الاقتران المكوّن من 6 أرقام الظاهر على جهاز Trezor."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "输入您的 Trezor 上显示的 6 位配对码。"
          }
        }
      }
    },
    "Enter the URL of an Apps catalog to add it alongside the built-in one.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "أدخل عنوان URL لكتالوج Apps لإضافته إلى جانب الكتالوج المدمج."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "输入 Apps 目录的网址，将其添加到内置目录之外。"
          }
        }
      }
    },
    "Enter the passphrase you used for this backup, then pick the file. Maknoon decrypts it on this phone to confirm it opens. Nothing on this device is changed.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "أدخل عبارة المرور التي استخدمتها لهذه النسخة الاحتياطية، ثم اختر الملف. يقوم Maknoon بفك تشفيره على هذا الهاتف للتأكد من أنه يُفتح. لا يتم تغيير أي شيء على هذا الجهاز."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "输入您为此备份使用的密码短语，然后选择文件。Maknoon 会在此手机上解密以确认其可以打开。本设备上的任何内容都不会被更改。"
          }
        }
      }
    },
    "Enter the passphrase you used when you encrypted this backup, then pick the file. Decryption and verification happen entirely on this phone.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "أدخل عبارة المرور التي استخدمتها عند تشفير هذه النسخة الاحتياطية، ثم اختر الملف. يتم فك التشفير والتحقق بالكامل على هذا الهاتف."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter the passphrase you used when you encrypted this backup, then pick the file. Decryption and verification happen entirely on this phone."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "输入加密此备份时使用的口令短语，然后选择文件。解密和验证完全在本机完成。"
          }
        }
      }
    },
    "Enter the password you used for this backup, then pick the file. Maknoon decrypts it on this phone to confirm it opens. Nothing on this device is changed.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "أدخل كلمة المرور التي استخدمتها لهذه النسخة الاحتياطية، ثم اختر الملف. يفك Maknoon تشفيرها على هذا الهاتف للتأكد من أنها تُفتح. لا يتم تغيير أي شيء على هذا الجهاز."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "输入您用于此备份的密码，然后选择文件。Maknoon 会在此手机上解密它以确认能够打开。此设备上的任何内容都不会被更改。"
          }
        }
      }
    },
    "Enter the word at each position. We pick three positions at random so you can prove you copied the phrase correctly.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "أدخل الكلمة في كل موضع. نختار ثلاثة مواضع عشوائياً لتثبت أنك نسخت العبارة بشكل صحيح."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter the word at each position. We pick three positions at random so you can prove you copied the phrase correctly."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "请输入对应位置的单词。我们会随机选择三个位置，以验证您是否正确抄录了助记词。"
          }
        }
      }
    },
    "Enter your YubiKey FIDO2 PIN to authorize.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "أدخل رمز PIN لـ FIDO2 الخاص بـ YubiKey للتفويض."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "输入您的 YubiKey FIDO2 PIN 以授权。"
          }
        }
      }
    },
    "Enter your YubiKey FIDO2 PIN. Leave blank if no PIN is set on the key.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "أدخل رمز PIN لـ FIDO2 الخاص بـ YubiKey. اتركه فارغًا إذا لم يكن هناك رمز PIN معيّن على المفتاح."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "输入您的 YubiKey FIDO2 PIN。如果该密钥未设置 PIN，请留空。"
          }
        }
      }
    },
    "Erases the master, ephemeral, and delegation from this device. You cannot undo this, restore from your recovery phrase or encrypted backup if you change your mind.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يمحو المفتاح الرئيسي والمؤقت والتفويض من هذا الجهاز. لا يمكنك التراجع عن هذا، استعد من عبارة الاسترداد أو النسخة الاحتياطية المشفرة إذا غيّرت رأيك."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Erases the master, ephemeral, and delegation from this device. You cannot undo this, restore from your recovery phrase or encrypted backup if you change your mind."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "从此设备清除主密钥、临时密钥和委托密钥。此操作无法撤销，如需恢复请使用助记词或加密备份。"
          }
        }
      }
    },
