          }
        }
      }
    },
    "Secure Enclave signing unlocks the post-quantum master key locally via your preferred configured biometric or passcode. Registered security keys add a hardware second factor that wraps the BIP39 entropy via a FIDO2 hmac-secret challenge-response." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "يفتح توقيع Secure Enclave المفتاح الرئيسي ما بعد الكم محلياً عبر المقياس الحيوي أو رمز المرور المُكوَّن المفضل لديك. تضيف مفاتيح الأمان المسجلة عاملاً ثانياً مادياً يغلف إنتروبيا BIP39 عبر تحدي/استجابة FIDO2 hmac-secret."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Secure Enclave signing unlocks the post-quantum master key locally via your preferred configured biometric or passcode. Registered security keys add a hardware second factor that wraps the BIP39 entropy via a FIDO2 hmac-secret challenge-response."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Secure Enclave 签名通过您配置的首选生物识别或设备密码在本地解锁后量子主密钥。已注册的安全密钥提供硬件第二因素，通过 FIDO2 hmac-secret 挑战响应封装 BIP39 熵。"
          }
        }
      }
    },
