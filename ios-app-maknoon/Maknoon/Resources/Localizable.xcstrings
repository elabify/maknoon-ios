    "Advanced: use your own price and exchange-rate sources instead of the defaults.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "متقدم: استخدم مصادرك الخاصة للأسعار وأسعار الصرف بدلاً من الافتراضية."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "高级：使用您自己的价格和汇率来源，而非默认来源。"
          }
        }
      }
    },
    "Air-gapped Bitcoin signer paired by scanning QR codes.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "موقّع Bitcoin معزول هوائياً يُقترن بمسح رموز QR."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "通过扫描 QR 码配对的离线 Bitcoin 签名器。"
          }
        }
      }
    },
    "All": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "الكل"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "全部"
          }
        }
      }
    },
    "All attributes are selected by default. Tap to remove any field before building the QR; required fields (when the verifier specified them) stay on.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "جميع السمات محددة افتراضياً. اضغط لإزالة أي حقل قبل بناء رمز QR، وتبقى الحقول المطلوبة (عند تحديدها من قبل المحقق) مفعّلة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All attributes are selected by default. Tap to remove any field before building the QR; required fields (when the verifier specified them) stay on."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "默认勾选所有属性。生成二维码前可点击移除任意字段；验证方指定的必填字段会保持选中。"
          }
        }
      }
    },
    "Also checks BIP44 (legacy 1…), BIP49 (nested SegWit 3…) and BIP84 (native SegWit bc1q…) per account, so a wallet from another app is found. Slower: a full scan per script type.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يتحقق أيضًا من BIP44 (القديم 1…) وBIP49 (SegWit المتداخل 3…) وBIP84 (SegWit الأصلي bc1q…) لكل حساب، بحيث يتم العثور على محفظة من تطبيق آخر. أبطأ: فحص كامل لكل نوع نص برمجي."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "还会为每个账户检查 BIP44（旧式 1…）、BIP49（嵌套 SegWit 3…）和 BIP84（原生 SegWit bc1q…），以便找到来自其他应用的钱包。较慢：对每种脚本类型进行完整扫描。"
          }
        }
      }
    },
    "Also checks well-known non-standard paths (Ledger Live, MEW legacy, …) so a wallet created in another app is found. Slower: more lookups per account.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يتحقق أيضًا من المسارات غير القياسية المعروفة (Ledger Live وMEW القديم و…) بحيث يتم العثور على محفظة أُنشئت في تطبيق آخر. أبطأ: عمليات بحث أكثر لكل حساب."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "还会检查知名的非标准路径（Ledger Live、MEW 旧式等），以便找到在其他应用中创建的钱包。较慢：每个账户的查询次数更多。"
          }
        }
      }
    },
    "Also checks well-known non-standard paths (Ledger, TIP-01, …) so a wallet created in another app is found.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يتحقق أيضًا من المسارات غير القياسية المعروفة (Ledger وTIP-01 و…) بحيث يتم العثور على محفظة أُنشئت في تطبيق آخر."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "还会检查知名的非标准路径（Ledger、TIP-01 等），以便找到在其他应用中创建的钱包。"
          }
        }
      }
    },
    "Also checks well-known non-standard paths (e.g. Ledger Live's m/44'/501'/N') so a wallet created in another app is found.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يتحقق أيضًا من المسارات غير القياسية المعروفة (مثل m/44'/501'/N' في Ledger Live) بحيث يتم العثور على محفظة أُنشئت في تطبيق آخر."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "还会检查知名的非标准路径（例如 Ledger Live 的 m/44'/501'/N'），以便找到在其他应用中创建的钱包。"
          }
        }
      }
    },
    "Also scan Testnet3 + Signet": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
