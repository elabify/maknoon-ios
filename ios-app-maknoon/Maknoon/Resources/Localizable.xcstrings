    "Open a hidden wallet by typing its passphrase on the Trezor. The phone never sees it. A different passphrase is a different wallet.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "افتح محفظة مخفية بكتابة عبارة المرور الخاصة بها على Trezor. لا يراها الهاتف أبدًا. عبارة المرور المختلفة تعني محفظة مختلفة."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "通过在 Trezor 上输入密码短语来打开隐藏钱包。手机永远不会看到它。不同的密码短语对应不同的钱包。"
          }
        }
      }
    },
