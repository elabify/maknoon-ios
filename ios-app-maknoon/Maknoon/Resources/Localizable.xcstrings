    },
    "Pick the encrypted backup file you saved earlier (anywhere in iCloud Drive, On My iPhone, or another Files-app location). You will need the passphrase." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "اختر ملف النسخة الاحتياطية المشفر الذي حفظته سابقاً (في أي مكان في iCloud Drive أو On My iPhone أو أي موقع آخر في تطبيق الملفات). ستحتاج إلى عبارة المرور."
          }
        },
        "en" : {
          "stringUnit" : {
