    "Scans accounts 0-4 on each selected network. Mainnet only by default; turn this on if you regularly use the public testnets.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يفحص الحسابات 0-4 على كل شبكة محددة. الشبكة الرئيسية فقط افتراضياً، فعّل هذا إذا كنت تستخدم شبكات الاختبار العامة بانتظام."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Scans accounts 0-4 on each selected network. Mainnet only by default; turn this on if you regularly use the public testnets."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "对每个选中的网络扫描账户 0 到 4。默认仅扫描主网；如您经常使用公共测试网，请启用此项。"
          }
        }
      }
    },
    "Scans accounts on %@ from this device until 4 consecutive empty accounts are found, then stops.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يمسح الحسابات على %@ من هذا الجهاز حتى يُعثر على 4 حسابات فارغة متتالية، ثم يتوقف."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "从此设备扫描 %@ 上的账户，直到找到 4 个连续的空账户后停止。"
          }
        }
      }
    },
    "Scans accounts on %@ under your Identity Sandwich seed until 4 consecutive empty accounts are found, then stops.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يمسح الحسابات على %@ ضمن بذرة Identity Sandwich الخاصة بك حتى يُعثر على 4 حسابات فارغة متتالية، ثم يتوقف."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "在您的 Identity Sandwich 种子下扫描 %@ 上的账户，直到找到 4 个连续的空账户后停止。"
          }
        }
      }
    },
    "Scans accounts on %@ under your Identity Sandwich seed until 4 consecutive empty accounts are found, then stops. Use this when restoring from a backup that already has on-chain activity.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يمسح الحسابات على %@ ضمن بذرة Identity Sandwich الخاصة بك حتى يُعثر على 4 حسابات فارغة متتالية، ثم يتوقف. استخدم هذا عند الاستعادة من نسخة احتياطية لها نشاط على السلسلة بالفعل."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "在您的 Identity Sandwich 种子下扫描 %@ 上的账户，直到找到 4 个连续的空账户后停止。在从已有链上活动的备份恢复时使用此功能。"
          }
        }
      }
    },
    "Scans accounts on %@ until 4 consecutive empty accounts are found, then stops. Use this when restoring from a backup that already has on-chain activity.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يمسح الحسابات على %@ حتى يُعثر على 4 حسابات فارغة متتالية، ثم يتوقف. استخدم هذا عند الاستعادة من نسخة احتياطية لها نشاط على السلسلة بالفعل."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "扫描 %@ 上的账户，直到找到 4 个连续的空账户后停止。在从已有链上活动的备份恢复时使用此功能。"
          }
        }
      }
    },
    "Scans accounts on %@ until 4 consecutive empty accounts are found, then stops. Use this when restoring from a device you've used before.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يمسح الحسابات على %@ حتى يُعثر على 4 حسابات فارغة متتالية، ثم يتوقف. استخدم هذا عند الاستعادة من جهاز استخدمته من قبل."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "扫描 %@ 上的账户，直到找到 4 个连续的空账户后停止。在从您以前使用过的设备恢复时使用此功能。"
          }
        }
      }
    },
