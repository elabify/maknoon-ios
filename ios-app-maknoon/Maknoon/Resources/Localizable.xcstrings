            "value": "解锁 Maknoon"
          }
        }
      }
    },
    "Unlock Maknoon first; signing needs your wallet's private key.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "افتح Maknoon أولاً؛ يحتاج التوقيع إلى المفتاح الخاص بمحفظتك."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "请先解锁 Maknoon；签名需要您钱包的私钥。"
          }
        }
      }
    },
    "Unlock the Ledger Nano X so we can locally confirm the device serial.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "افتح قفل Ledger Nano X حتى نتمكن من تأكيد الرقم التسلسلي للجهاز محلياً."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unlock the Ledger Nano X so we can locally confirm the device serial."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "请解锁 Ledger Nano X，以便我们在本地确认设备序列号。"
          }
        }
      }
    },
    "Unlock the Ledger and open the **%@** app. Maknoon will request the account public key over Bluetooth; approve the prompt on the device.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "افتح قفل Ledger وافتح تطبيق **%@**. سيطلب Maknoon المفتاح العام للحساب عبر Bluetooth، فوافق على المطالبة على الجهاز."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "解锁 Ledger 并打开 **%@** 应用。Maknoon 将通过蓝牙请求账户公钥，请在设备上批准该提示。"
          }
        }
      }
    },
    "Unlock the Ledger and open the **Bitcoin** app. Maknoon will request the account public key over Bluetooth; approve the prompt on the device.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "افتح قفل Ledger وافتح تطبيق **Bitcoin**. سيطلب Maknoon المفتاح العام للحساب عبر Bluetooth، وافق على المطالبة على الجهاز."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unlock the Ledger and open the **Bitcoin** app. Maknoon will request the account public key over Bluetooth; approve the prompt on the device."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "解锁 Ledger 并打开 **Bitcoin** 应用。Maknoon 将通过蓝牙请求账户公钥，请在设备上批准该提示。"
          }
        }
      }
    },
    "Unlock the Trezor and approve the account public key request on the device.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "افتح قفل Trezor ووافق على طلب المفتاح العام للحساب على الجهاز."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "解锁 Trezor 并在设备上批准账户公钥请求。"
          }
        }
      }
    },
    "Unlock with hardware device": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "الفتح باستخدام جهاز الأجهزة"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "使用硬件设备解锁"
          }
        }
