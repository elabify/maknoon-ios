    "Confirm the transaction on your hardware device when prompted. The device verifies the recipient, value, and gas cap on-screen before signing.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "أكّد المعاملة على جهازك المادي عند المطالبة. يتحقق الجهاز من المستلم والقيمة وحد الغاز على الشاشة قبل التوقيع."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Confirm the transaction on your hardware device when prompted. The device verifies the recipient, value, and gas cap on-screen before signing."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "按提示在硬件设备上确认交易。设备会在签名前在屏幕上核验收款人、金额和 gas 上限。"
          }
        }
      }
    },
    "Confirm the wrap signature on your Trezor's touchscreen. The device times out after ~30s of no input.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "أكّد توقيع التغليف على شاشة لمس Trezor الخاصة بك. تنتهي مهلة الجهاز بعد نحو 30 ثانية من عدم الإدخال."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "在 Trezor 的触摸屏上确认封装签名。设备在约 30 秒无输入后超时。"
          }
        }
      }
    },
