    "Place of birth": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "مكان الميلاد"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "出生地"
          }
        }
      }
    },
    "Plug a YubiKey 5C into the iPhone's USB-C port. Approve the accessory prompt iOS shows the first time you connect it. Maknoon reads the key's serial number; if the YubiKey is PIN-protected you'll be asked for the PIN.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "وصّل YubiKey 5C بمنفذ USB-C في iPhone. وافق على مطالبة الملحقات التي يعرضها iOS في أول مرة توصله فيها. يقرأ Maknoon الرقم التسلسلي للمفتاح، وإذا كان YubiKey محمياً برمز PIN، فسيُطلب منك الرمز."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Plug a YubiKey 5C into the iPhone's USB-C port. Approve the accessory prompt iOS shows the first time you connect it. Maknoon reads the key's serial number; if the YubiKey is PIN-protected you'll be asked for the PIN."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "将 YubiKey 5C 插入 iPhone 的 USB-C 端口。首次连接时请允许 iOS 弹出的配件提示。Maknoon 会读取该密钥的序列号；如果 YubiKey 设置了 PIN，将提示您输入 PIN。"
          }
        }
      }
    },
    "Point at the issuer's QR code": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "وجّه نحو رمز QR للمصدر"
