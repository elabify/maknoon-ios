        }
      }
    },
    "You also have a password": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "لديك أيضاً كلمة مرور"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "您还设置了密码"
          }
        }
      }
    },
    "You declined the on-device confirmation. Tap the right button on the Ledger to approve, then retry.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "لقد رفضت التأكيد على الجهاز. اضغط على الزر الأيمن في Ledger للموافقة، ثم أعد المحاولة."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "您拒绝了设备上的确认。请按 Ledger 上的右键以批准，然后重试。"
          }
        }
      }
    },
    "You did not set a passphrase at onboarding, so we cannot encrypt a backup. The 24 offline words remain your only recovery path.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "لم تقم بتعيين عبارة مرور أثناء الإعداد، لذا لا يمكننا تشفير نسخة احتياطية. تبقى الكلمات الـ 24 غير المتصلة مسار الاسترداد الوحيد لديك."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You did not set a passphrase at onboarding, so we cannot encrypt a backup. The 24 offline words remain your only recovery path."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "您在引导流程中未设置口令短语，因此无法对备份进行加密。24 个离线助记词仍是您唯一的恢复方式。"
          }
        }
      }
    },
    "You did not set a password at onboarding, so we cannot encrypt a backup. The 24 offline words remain your only recovery path.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "لم تقم بتعيين كلمة مرور عند الإعداد، لذا لا يمكننا تشفير نسخة احتياطية. تبقى الكلمات الـ24 غير المتصلة مسار الاسترداد الوحيد لديك."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "您在初始设置时未设置密码，因此我们无法加密备份。24 个离线词仍是您唯一的恢复途径。"
          }
        }
      }
    },
    "You don't have a verified credential matching this request.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ليس لديك بيانات اعتماد موثقة تطابق هذا الطلب."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "您没有与此请求匹配的已验证凭证。"
          }
        }
      }
    },
    "You send": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "أنت ترسل"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You send"
          }
        },
        "zh-Hans": {
          "stringUnit": {
