    "On Device": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "على الجهاز"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "在设备上"
          }
        }
      }
    },
    "On the SeedSigner: Seeds → Select your seed → Export Xpub → Single Sig → Native Segwit → BlueWallet → I Understand → Export Xpub. Scan the static QR it shows, or paste the text exported alongside it. Sparrow and Specter exports work via paste but emit animated multi-frame QR that Maknoon's single-frame scanner can't assemble yet.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "على SeedSigner: Seeds ← اختر بذرتك ← Export Xpub ← Single Sig ← Native Segwit ← BlueWallet ← I Understand ← Export Xpub. افحص رمز QR الثابت الذي يعرضه، أو الصق النص المُصدَّر معه. تعمل تصديرات Sparrow و Specter عبر اللصق ولكنها تصدر رمز QR متحرك متعدد الإطارات لا يستطيع ماسح Maknoon أحادي الإطار تجميعه بعد."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "On the SeedSigner: Seeds → Select your seed → Export Xpub → Single Sig → Native Segwit → BlueWallet → I Understand → Export Xpub. Scan the static QR it shows, or paste the text exported alongside it. Sparrow and Specter exports work via paste but emit animated multi-frame QR that Maknoon's single-frame scanner can't assemble yet."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "在 SeedSigner 上：Seeds → 选择您的种子 → Export Xpub → Single Sig → Native Segwit → BlueWallet → I Understand → Export Xpub。扫描其显示的静态二维码，或粘贴随之导出的文本。Sparrow 和 Specter 的导出可通过粘贴使用，但它们生成的是多帧动态二维码，Maknoon 的单帧扫描器目前还无法拼装。"
          }
        }
      }
    },
    "On-device authorization": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "التفويض على الجهاز"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "On-device authorization"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "设备上授权"
          }
        }
      }
    },
    "Once shipped this screen will hold the RPC endpoint (default: a public Infura / Alchemy / Ankr endpoint), the EIP-1559 fee oracle endpoint, the Etherscan API base, and the chain ID picker (mainnet, Sepolia, Holesky).": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "بمجرد إطلاقها، ستحتوي هذه الشاشة على نقطة نهاية RPC (افتراضياً: نقطة نهاية Infura / Alchemy / Ankr عامة)، ونقطة نهاية مرجع رسوم EIP-1559، وقاعدة Etherscan API، ومنتقي معرف السلسلة (الشبكة الرئيسية، Sepolia، Holesky)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Once shipped this screen will hold the RPC endpoint (default: a public Infura / Alchemy / Ankr endpoint), the EIP-1559 fee oracle endpoint, the Etherscan API base, and the chain ID picker (mainnet, Sepolia, Holesky)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "该功能发布后，此页面将包含 RPC 端点（默认：公共 Infura / Alchemy / Ankr 端点）、EIP-1559 手续费预测端点、Etherscan API 基础地址以及链 ID 选择器（主网、Sepolia、Holesky）。"
          }
        }
      }
    },
    "Once shipped this screen will hold the RPC endpoint (default: a public mainnet-beta endpoint), the Solana Explorer base URL, and a devnet/testnet toggle.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "بمجرد إطلاقها، ستحتوي هذه الشاشة على نقطة نهاية RPC (افتراضياً: نقطة نهاية mainnet-beta عامة)، وعنوان URL الأساسي لـ Solana Explorer، ومفتاح تبديل devnet/testnet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Once shipped this screen will hold the RPC endpoint (default: a public mainnet-beta endpoint), the Solana Explorer base URL, and a devnet/testnet toggle."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "该功能发布后，此页面将包含 RPC 端点（默认：公共 mainnet-beta 端点）、Solana Explorer 基础 URL，以及 devnet/testnet 开关。"
          }
        }
      }
    },
    "One confirmation shares the attributes above and pays from the selected wallet. Your keys never leave this device.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "تأكيد واحد يشارك السمات أعلاه ويدفع من المحفظة المحددة. مفاتيحك لا تغادر هذا الجهاز أبدًا."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "一次确认即可分享上述属性并从所选钱包付款。您的密钥永远不会离开此设备。"
          }
        }
      }
    },
    "One scan kicks off a Bluetooth session. The Presentation flows directly between the two phones, encrypted with a fresh post-quantum key. No server in the middle.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يبدأ فحص واحد جلسة Bluetooth. يتدفق العرض مباشرة بين الهاتفين، مشفراً بمفتاح جديد ما بعد الكم. لا يوجد خادم في الوسط."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One scan kicks off a Bluetooth session. The Presentation flows directly between the two phones, encrypted with a fresh post-quantum key. No server in the middle."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "一次扫描即可启动蓝牙会话。展示信息在两部手机之间直接传输，并使用新的后量子密钥加密。中间没有任何服务器。"
          }
        }
      }
    },
    "Online QR": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "رمز QR عبر الإنترنت"
