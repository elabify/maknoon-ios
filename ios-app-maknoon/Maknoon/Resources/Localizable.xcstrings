    "Write these words on paper or stamped metal. Store OFFLINE. Never type them into a computer, never photograph or screenshot.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "اكتب هذه الكلمات على ورق أو معدن مختوم. خزّن دون اتصال. لا تكتبها أبداً في كمبيوتر، ولا تصوّرها أو تأخذ لقطة شاشة لها."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Write these words on paper or stamped metal. Store OFFLINE. Never type them into a computer, never photograph or screenshot."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "请将这些单词写在纸张或压印的金属上，离线存放。切勿输入到电脑中，切勿拍照或截屏。"
          }
        }
      }
    },
    "You also have a passphrase": {
      "extractionState": "manual",
      "localizations": {
