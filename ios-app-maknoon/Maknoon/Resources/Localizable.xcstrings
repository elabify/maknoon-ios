    "Tor toggle is stored but not yet wired; enabling has no runtime effect until the Tor transport ships.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يُحفظ مفتاح Tor لكنه غير موصل بعد، التفعيل ليس له تأثير وقت التشغيل حتى يتم إطلاق ناقل Tor."
          }
        },
