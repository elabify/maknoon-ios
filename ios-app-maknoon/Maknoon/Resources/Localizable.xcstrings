          }
        }
      }
    },
    "Hold steady, let the rotating QR cycle once.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ثبّت الهاتف، ودع رمز QR الدوار يكمل دورة واحدة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold steady, let the rotating QR cycle once."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "保持稳定，让动态二维码完整循环一遍。"
          }
        }
      }
    },
    "Hold steady. The verifier's wallet collects every frame, then assembles your Presentation locally. No server in the loop.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ثبّت الهاتف. تجمع محفظة المحقق كل إطار، ثم تركّب عرضك محلياً. لا يوجد خادم في الحلقة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold steady. The verifier's wallet collects every frame, then assembles your Presentation locally. No server in the loop."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "保持稳定。验证方的钱包会收集每一帧，并在本地拼装出您的展示。整个过程不经过服务器。"
          }
        }
      }
    },
    "Hold steady. The verifier's wallet collects every frame, then assembles your Presentation locally. No server in the loop. If the scanner is missing frames, slide toward the tortoise.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "حافظ على الثبات. تجمع محفظة جهة التحقق كل إطار، ثم تجمّع عرضك محليًا. لا يوجد خادم في العملية. إذا كان الماسح يفقد إطارات، حرّك نحو السلحفاة."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "保持稳定。验证方的钱包会收集每一帧，然后在本地组装您的演示文稿。过程中不涉及服务器。如果扫描器丢失帧，请向乌龟方向滑动。"
          }
        }
      }
    },
    "Hold the SeedSigner camera 6-10 inches from the phone": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "احمل كاميرا SeedSigner على بُعد 6 إلى 10 بوصات من الهاتف"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold the SeedSigner camera 6-10 inches from the phone"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "将 SeedSigner 摄像头距手机 6 至 10 英寸（约 15 至 25 厘米）保持稳定"
          }
        }
      }
    },
    "Hold your SeedSigner camera up to the phone when the animated QR appears. Maknoon collects the signed transaction back through this phone's camera.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "احمل كاميرا SeedSigner مقابل الهاتف عند ظهور رمز QR المتحرك. يجمع Maknoon المعاملة الموقعة من خلال كاميرا هذا الهاتف."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold your SeedSigner camera up to the phone when the animated QR appears. Maknoon collects the signed transaction back through this phone's camera."
          }
        },
