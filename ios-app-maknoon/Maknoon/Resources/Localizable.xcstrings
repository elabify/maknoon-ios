    },
    "Send the document's chip-signed fields to an issuer for verification and sanctions screening. You get back a post-quantum credential, anchored privately on ledger, that any compatible verifier can check.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "أرسل الحقول الموقّعة بشريحة المستند إلى جهة إصدار للتحقق وفحص العقوبات. ستحصل في المقابل على بيانات اعتماد ما بعد كمية، مثبّتة بشكل خاص على دفتر الأستاذ، يمكن لأي جهة تحقق متوافقة فحصها."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "将文件的芯片签名字段发送给发行方进行验证和制裁筛查。您将获得一份后量子凭证，私密地锚定在账本上，任何兼容的验证方都可以查验。"
          }
        }
      }
    },
