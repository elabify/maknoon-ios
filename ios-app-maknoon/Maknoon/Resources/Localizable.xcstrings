    "Walks BIP44 accounts 0 through 4 on the selected network and pre-adds any that already have on-chain activity.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يمر بحسابات BIP44 من 0 إلى 4 على الشبكة المحددة ويضيف مسبقاً أي حساب لديه نشاط على السلسلة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Walks BIP44 accounts 0 through 4 on the selected network and pre-adds any that already have on-chain activity."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "在所选网络上遍历 BIP44 账户 0 到 4，并自动预添加任何已有链上活动的账户。"
          }
        }
      }
    },
    "Walks BIP44 accounts on %@ under your Identity Sandwich seed until %@ consecutive empty accounts are found. Reads the seed once, then queries TronGrid for balance + recent activity per account.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Walks BIP44 accounts on %1$@ under your Identity Sandwich seed until %2$@ consecutive empty accounts are found. Reads the seed once, then queries TronGrid for balance + recent activity per account."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يمر عبر حسابات BIP44 على %@ ضمن بذرة Identity Sandwich الخاصة بك حتى يُعثر على %@ حسابات فارغة متتالية. يقرأ البذرة مرة واحدة، ثم يستعلم من TronGrid عن الرصيد والنشاط الأخير لكل حساب."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "在 %@ 上遍历您的 Identity Sandwich 种子下的 BIP44 账户，直到找到 %@ 个连续的空账户。读取种子一次，然后向 TronGrid 查询每个账户的余额和近期活动。"
          }
        }
      }
    },
    "Walks accounts 0 through 4 and checks each address for on-chain activity. Active accounts get pre-selected so you can add them in one tap.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يمر بالحسابات من 0 إلى 4 ويفحص كل عنوان للنشاط على السلسلة. تُحدد الحسابات النشطة مسبقاً لتتمكن من إضافتها بضغطة واحدة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Walks accounts 0 through 4 and checks each address for on-chain activity. Active accounts get pre-selected so you can add them in one tap."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "遍历账户 0 到 4，并检查每个地址的链上活动。有活动的账户会被预选，您只需一次点击即可添加。"
          }
        }
      }
    },
    "Walks accounts 0, 1, 2, ... under your Identity Sandwich seed on %@ until %@ consecutive empty accounts are found. Reads the seed once, then queries the configured RPC for balance + signatures per account.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Walks accounts 0, 1, 2, ... under your Identity Sandwich seed on %1$@ until %2$@ consecutive empty accounts are found. Reads the seed once, then queries the configured RPC for balance + signatures per account."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يمر عبر الحسابات 0، 1، 2، ... ضمن بذرة Identity Sandwich الخاصة بك على %@ حتى يُعثر على %@ حسابات فارغة متتالية. يقرأ البذرة مرة واحدة، ثم يستعلم من RPC المُكوّن عن الرصيد والتوقيعات لكل حساب."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "在 %@ 上遍历您的 Identity Sandwich 种子下的账户 0、1、2、...，直到找到 %@ 个连续的空账户。读取种子一次，然后向所配置的 RPC 查询每个账户的余额和签名。"
          }
        }
      }
    },
    "Walks accounts from this device on %@ until 4 consecutive empty accounts are found, then stops.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "يمر عبر الحسابات من هذا الجهاز على %@ حتى يُعثر على 4 حسابات فارغة متتالية، ثم يتوقف."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "在 %@ 上遍历此设备的账户，直到找到 4 个连续的空账户后停止。"
          }
        }
      }
    },
