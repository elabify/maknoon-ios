    "%@ is a Tron testnet. The catalog covers mainnet contracts only, so testnet tokens always land in the custom path. Get the testnet-specific contract address from %@'s explorer (mainnet USDT / USDC contracts do not exist on %@).": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ is a Tron testnet. The catalog covers mainnet contracts only, so testnet tokens always land in the custom path. Get the testnet-specific contract address from %2$@'s explorer (mainnet USDT / USDC contracts do not exist on %3$@)."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%@ هي شبكة اختبار Tron. يغطي الكتالوج عقود الشبكة الرئيسية فقط، لذا تنتهي رموز شبكة الاختبار دائمًا في المسار المخصص. احصل على عنوان العقد الخاص بشبكة الاختبار من مستكشف %@ (عقود USDT / USDC للشبكة الرئيسية غير موجودة على %@)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%@ 是 Tron 测试网。目录仅涵盖主网合约，因此测试网代币始终归入自定义路径。请从 %@ 的浏览器获取测试网专用的合约地址（主网 USDT / USDC 合约在 %@ 上并不存在）。"
          }
        }
      }
    },
    "%@ of 24 words": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%@ من 24 كلمة"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "24 个词中的第 %@ 个"
