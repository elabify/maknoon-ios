    "Posts the signed Presentation to this URL. Works with any verifier; you can copy the body separately to inspect it first.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ينشر العرض الموقع إلى هذا العنوان. يعمل مع أي محقق، يمكنك نسخ المحتوى منفصلاً لفحصه أولاً."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Posts the signed Presentation to this URL. Works with any verifier; you can copy the body separately to inspect it first."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "将已签名的展示发送到此 URL。适用于任何验证方；您也可以先单独复制内容进行查看。"
          }
        }
      }
    },
    "Pre-selected the accounts with activity. Existing wallets are skipped automatically.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "تم تحديد الحسابات ذات النشاط مسبقاً. يتم تخطي المحافظ الموجودة تلقائياً."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pre-selected the accounts with activity. Existing wallets are skipped automatically."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "已预选有活动的账户。已存在的钱包会自动跳过。"
          }
        }
      }
    },
    "Pre-selected the accounts with activity. Existing wallets at the same account index are skipped automatically.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "تم تحديد الحسابات ذات النشاط مسبقًا. تُتجاوز المحافظ الموجودة عند نفس فهرس الحساب تلقائيًا."
          }
        },
        "zh-Hans": {
          "stringUnit": {
