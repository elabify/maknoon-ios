    "NFC YubiKey scanning is disabled in this build because it requires the paid Apple Developer Program. USB-C works with a free Personal Team.": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "فحص YubiKey عبر NFC معطل في هذه النسخة لأنه يتطلب برنامج Apple Developer المدفوع. يعمل USB-C مع فريق شخصي مجاني."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "NFC YubiKey scanning is disabled in this build because it requires the paid Apple Developer Program. USB-C works with a free Personal Team."
