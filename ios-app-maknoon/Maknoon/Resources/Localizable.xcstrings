    "A passphrase is an extra secret combined with your 24-word recovery phrase. You will need BOTH to recover your identity." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "عبارة المرور هي سر إضافي يُدمج مع عبارة الاسترداد المكونة من 24 كلمة. ستحتاج إلى كليهما لاسترداد هويتك."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A passphrase is an extra secret combined with your 24-word recovery phrase. You will need BOTH to recover your identity."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "口令短语是与 24 个助记词组合使用的额外密钥。恢复身份时两者缺一不可。"
          }
        }
      }
    },
